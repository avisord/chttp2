---
Plan: Optional TLS/HTTPS for chttp2

 Context

 The chttp framework currently uses raw int fd for all client I/O. Adding optional TLS requires a CConn abstraction that wraps fd + SSL* so every I/O call can transparently
 dispatch to either write()/recv() or SSL_write()/SSL_read(). The key constraint is that handler signatures (WsHandler, SseHandler) and streaming handlers in fs.c/static.c
 all hold int fd directly — every one of those must migrate to CConn*.

 Approach: CConn abstraction + OpenSSL, compile-time optional

 #ifdef CHTTP_TLS guards all SSL code. Build plain with make, build with TLS with make TLS=1.

 ---
 New Public API (in lib/chttp.h)

 /* Opaque connection handle (wraps fd + optional SSL*) */
 typedef struct CConn CConn;

 /* TLS enablement — call before chttp_server_run() */
 int chttp_server_enable_tls(HttpServer *srv, const char *cert_path, const char *key_path);

 /* CConn accessors (for callers that need the raw fd, e.g. dup2 in auth.c) */
 int     chttp_conn_fd(CConn *conn);
 ssize_t chttp_conn_write(CConn *conn, const void *buf, size_t n);
 ssize_t chttp_conn_recv(CConn *conn, void *buf, size_t n, int flags);
 int     chttp_conn_sendfile(CConn *conn, int file_fd, size_t count); /* TLS-aware */

 /* Changed signatures */
 int  chttp_write_response(CConn *conn, HttpResponse *res);
 int  chttp_ws_send(CConn *conn, const char *payload, size_t len);
 int  chttp_ws_recv(CConn *conn, char *buf, size_t bufsize);
 int  chttp_sse_send(CConn *conn, const char *event, const char *data);

 /* Changed handler typedefs */
 typedef void (*WsHandler)(CConn *conn);
 typedef void (*SseHandler)(CConn *conn);

 /* HttpRequest: replace int fd with CConn *conn */
 // req->fd  →  req->conn (CConn*)
 // raw fd still accessible via chttp_conn_fd(req->conn)

