  # Run with cert/key
  sudo ./dist/server --tls /path/to/cert.pem /path/to/key.pem
  # or via env
  sudo CHTTP_TLS_CERT=cert.pem CHTTP_TLS_KEY=key.pem ./dist/server

  # Generate a self-signed cert for testing
  openssl req -x509 -newkey rsa:2048 -keyout key.pem -out cert.pem \
    -days 365 -nodes -subj '/CN=localhost'

