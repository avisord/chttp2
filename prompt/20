 ---
 Fork + TLS safety

 After fork(), parent and child have separate virtual address spaces (COW). The SSL* is independent in each — SSL_free() in the parent does not affect the child's copy.

 - Child: owns the connection, does chttp_conn_close(conn) (full SSL_shutdown)
 - Parent: does chttp_conn_free(conn) — SSL_free() (no shutdown) + close(fd) + free(conn)

 The parent must not send TLS close_notify because the child still has the connection open.

 ---
 sendfile + TLS

 sendfile() is a kernel syscall that bypasses userspace — it cannot pass data through SSL_write(). chttp_conn_sendfile() implementation:
 int chttp_conn_sendfile(CConn *conn, int file_fd, size_t count) {
 #ifdef CHTTP_TLS
     if (conn->ssl) {
         /* fallback: read into buffer, SSL_write in chunks */
         char buf[65536];
         while (count > 0) {
             ssize_t r = read(file_fd, buf, MIN(sizeof(buf), count));
             if (r <= 0) return -1;
             if (SSL_write(conn->ssl, buf, r) <= 0) return -1;
             count -= r;
         }
         return 0;
     }
 #endif
     /* plain: use sendfile */
     off_t offset = 0;
     while (count > 0) {
         ssize_t s = sendfile(conn->fd, file_fd, &offset, count);
         if (s <= 0) return -1;
         count -= s;
     }
     return 0;
 }

